rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Generated images — owner read/write only
    match /generated-images/{userId}/{allPaths=**} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Generated videos — owner read/write only
    match /generated-videos/{userId}/{allPaths=**} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // User uploaded assets — owner read/write, 10 MB cap
    match /user-assets/{userId}/{allPaths=**} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
