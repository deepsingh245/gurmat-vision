# Gemini API key — get from https://aistudio.google.com/app/apikey
# NOTE: This key is injected into the browser bundle at build time (temporary).
# Phase 5 will move all AI calls to Firebase Cloud Functions so this key
# never ships to the client.
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase — get from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
