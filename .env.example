# Firebase — get from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# GEMINI_API_KEY is no longer used in the frontend .env.
# It lives in Firebase Secret Manager (server-side only).
# To set it for deployment:
#   firebase functions:secrets:set GEMINI_API_KEY
# For local Functions emulator, create functions/.env.local:
#   GEMINI_API_KEY=your_key_here

# Google AdSense publisher ID — get from adsense.google.com → Account → Account Information
# Format: ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_CLIENT_ID=
